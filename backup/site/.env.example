# =============================================================================
# IPDR Platform — Per-Site Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values before deploying.
# Each site must have unique SITE_ID, SITE_HOST, and KAFKA_CLUSTER_ID.
# =============================================================================

# ── Required ───────────────────────────────────────────────────────────

# Unique identifier for this site. Used as collector_id on every record.
# Examples: site-a, karachi-dc1, lahore-core
SITE_ID=site-a

# External hostname or IP where this site's Kafka broker is reachable.
# Central ClickHouse will connect to this address.
# Examples: kafka-site-a.yourcompany.com, 203.0.113.10
SITE_HOST=kafka-site-a.yourcompany.com

# ── Optional ───────────────────────────────────────────────────────────

# Kafka external port (for central ClickHouse)
KAFKA_EXTERNAL_PORT=9094

# syslog ports
SYSLOG_UDP_PORT=514
SYSLOG_TCP_PORT=514
SYSLOG_TLS_PORT=6514

# Timezone
TZ=Asia/Karachi
