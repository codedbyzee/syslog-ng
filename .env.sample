# =============================================================================
# IPDR Platform — Combined Stack Environment
# =============================================================================
# Single-node all-in-one deployment.
# =============================================================================

# ── ClickHouse ────────────────────────────────────────────────────────
CLICKHOUSE_DB=ipdr
CLICKHOUSE_USER=ipdr_user
CLICKHOUSE_PASSWORD=ipdr_secret
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123

# ── syslog-ng ─────────────────────────────────────────────────────────
SYSLOG_UDP_PORT=514
SYSLOG_TCP_PORT=514
SYSLOG_TLS_PORT=6514

# ── Grafana ───────────────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PLUGINS=grafana-clickhouse-datasource

# ── Timezone ──────────────────────────────────────────────────────────
TZ=Asia/Karachi
