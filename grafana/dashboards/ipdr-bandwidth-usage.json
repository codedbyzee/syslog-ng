{
  "title": "IPDR Bandwidth Usage",
  "uid": "ipdr-bandwidth-usage",
  "version": 1,
  "schemaVersion": 39,
  "tags": [
    "ipdr",
    "bandwidth"
  ],
  "timezone": "browser",
  "editable": true,
  "refresh": "60s",
  "panels": [
    {
      "title": "Bandwidth by Service Type (Today)",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "rawSql": "SELECT service_type, sum(total_bytes) / 1073741824 AS gb FROM ipdr.ipdr_top_applications WHERE day = today() GROUP BY service_type ORDER BY gb DESC LIMIT 15",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "gigabytes",
          "color": {
            "mode": "continuous-blues"
          },
          "min": 0
        }
      },
      "description": "Total bandwidth consumption broken down by service type"
    },
    {
      "title": "Bandwidth by APN (Today)",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "rawSql": "SELECT apn, sum(total_bytes) / 1073741824 AS gb FROM ipdr.ipdr_top_applications WHERE day = today() AND apn != '' GROUP BY apn ORDER BY gb DESC",
          "queryType": "sql"
        }
      ],
      "description": "Bandwidth distribution across Access Point Names",
      "fieldConfig": {
        "defaults": {
          "unit": "gigabytes"
        }
      }
    },
    {
      "title": "Bandwidth by RAT Type (Today)",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "rawSql": "SELECT rat_type, sum(total_bytes) / 1073741824 AS gb FROM ipdr.ipdr_subscriber_bandwidth WHERE day = today() AND rat_type != '' GROUP BY rat_type ORDER BY gb DESC",
          "queryType": "sql"
        }
      ],
      "description": "Bandwidth distribution by Radio Access Technology (4G, 5G, etc.)",
      "fieldConfig": {
        "defaults": {
          "unit": "gigabytes"
        }
      }
    },
    {
      "title": "Daily Bandwidth Trend (30d)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 1,
          "rawSql": "SELECT day, sum(total_bytes_in) AS downstream, sum(total_bytes_out) AS upstream, sum(total_bytes) AS total FROM ipdr.ipdr_daily_aggregation WHERE day >= today() - 30 GROUP BY day ORDER BY day",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "fillOpacity": 15,
            "stacking": {
              "mode": "none"
            }
          }
        }
      },
      "description": "30-day trend of downstream, upstream, and total bandwidth"
    },
    {
      "title": "Top 10 Applications by Bandwidth (7d)",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "rawSql": "SELECT service_type, protocol, apn, sum(total_bytes) / 1073741824 AS gb, sum(total_bytes_in) / 1073741824 AS gb_in, sum(total_bytes_out) / 1073741824 AS gb_out, sum(session_count) AS sessions, sum(unique_subscribers) AS users FROM ipdr.ipdr_top_applications WHERE day >= today() - 7 GROUP BY service_type, protocol, apn ORDER BY gb DESC LIMIT 10",
          "queryType": "sql"
        }
      ],
      "description": "Top 10 application-protocol-APN combinations by bandwidth over 7 days",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "gb"
            },
            "properties": [
              {
                "id": "unit",
                "value": "gigabytes"
              },
              {
                "id": "displayName",
                "value": "Total GB"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "gb_in"
            },
            "properties": [
              {
                "id": "unit",
                "value": "gigabytes"
              },
              {
                "id": "displayName",
                "value": "Downstream GB"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "gb_out"
            },
            "properties": [
              {
                "id": "unit",
                "value": "gigabytes"
              },
              {
                "id": "displayName",
                "value": "Upstream GB"
              }
            ]
          }
        ]
      }
    },
    {
      "title": "Bandwidth per Service Over Time (7d)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 1,
          "rawSql": "SELECT day, service_type, sum(total_bytes) / 1073741824 AS gb FROM ipdr.ipdr_top_applications WHERE day >= today() - 7 GROUP BY day, service_type ORDER BY day",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "gigabytes",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "description": "Stacked bandwidth trend by service type over the last 7 days"
    },
    {
      "title": "Bandwidth Efficiency (bytes/sec)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 1,
          "rawSql": "SELECT day, service_type, sum(total_bytes) / sum(total_duration_sec) AS throughput FROM ipdr.ipdr_top_applications WHERE day >= today() - 7 AND total_duration_sec > 0 GROUP BY day, service_type ORDER BY day",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never"
          }
        }
      },
      "description": "Average throughput (bytes per second) by service type over time"
    },
    {
      "title": "Bandwidth Summary Stats",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "collapsed": false
    },
    {
      "title": "Total Bandwidth Today",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 25
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "rawSql": "SELECT sum(bytes_total) AS total FROM ipdr.ipdr_records WHERE timestamp >= toStartOfDay(now())",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "title": "Peak Hourly Bandwidth (Today)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 25
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "rawSql": "SELECT max(total_bytes) / 1048576 AS peak_mb FROM ipdr.ipdr_hourly_traffic WHERE hour >= toStartOfDay(now())",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "megabytes",
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        }
      }
    },
    {
      "title": "Avg Bandwidth per Service",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 25
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "rawSql": "SELECT sum(total_bytes) / uniqExact(service_type) / 1048576 AS avg_mb FROM ipdr.ipdr_top_applications WHERE day = today()",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "megabytes",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      }
    }
  ],
  "time": {
    "from": "now-7d",
    "to": "now"
  }
}