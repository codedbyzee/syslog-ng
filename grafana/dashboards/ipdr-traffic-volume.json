{
  "title": "IPDR Traffic Volume",
  "uid": "ipdr-traffic-volume",
  "version": 1,
  "schemaVersion": 39,
  "tags": [
    "ipdr",
    "traffic"
  ],
  "timezone": "browser",
  "editable": true,
  "refresh": "30s",
  "panels": [
    {
      "title": "Sessions per Second",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 1,
          "rawSql": "SELECT toStartOfInterval(timestamp, INTERVAL 1 SECOND) AS t, count() AS sessions FROM ipdr.ipdr_records WHERE $__timeFilter(timestamp) GROUP BY t ORDER BY t",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "fillOpacity": 20
          }
        }
      },
      "description": "Real-time session ingestion rate from Kafka into ClickHouse"
    },
    {
      "title": "Bandwidth Throughput",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 1,
          "rawSql": "SELECT toStartOfInterval(timestamp, INTERVAL 1 MINUTE) AS t, sum(bytes_in) AS downstream, sum(bytes_out) AS upstream FROM ipdr.ipdr_records WHERE $__timeFilter(timestamp) GROUP BY t ORDER BY t",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "fillOpacity": 15
          }
        }
      },
      "description": "Downstream vs upstream bandwidth over time"
    },
    {
      "title": "Hourly Traffic Pattern (24h)",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "rawSql": "SELECT toString(toHour(hour)) AS h, sum(total_bytes) / 1073741824 AS gb FROM ipdr.ipdr_hourly_traffic WHERE hour >= now() - INTERVAL 1 DAY GROUP BY h ORDER BY h",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "gigabytes",
          "color": {
            "mode": "continuous-blues"
          },
          "min": 0
        }
      },
      "description": "Bandwidth distribution across hours (last 24h)"
    },
    {
      "title": "Traffic by RAT Type (24h)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 1,
          "rawSql": "SELECT toStartOfInterval(hour, INTERVAL 1 HOUR) AS t, rat_type, sum(total_bytes) / 1048576 AS mb FROM ipdr.ipdr_hourly_traffic WHERE hour >= now() - INTERVAL 1 DAY GROUP BY t, rat_type ORDER BY t",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "megabytes",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "stacking": {
              "mode": "normal"
            }
          }
        }
      },
      "description": "Traffic breakdown by Radio Access Technology (4G, 5G, etc.)"
    },
    {
      "title": "Peak Hour Detection (7d)",
      "type": "heatmap",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 1,
          "rawSql": "SELECT toStartOfInterval(hour, INTERVAL 1 HOUR) AS t, toString(toHour(hour)) AS h, sum(total_bytes) / 1048576 AS mb FROM ipdr.ipdr_hourly_traffic WHERE hour >= now() - INTERVAL 7 DAY GROUP BY t, h ORDER BY t",
          "queryType": "sql"
        }
      ],
      "description": "Hourly traffic volume heatmap for peak hour identification"
    },
    {
      "title": "Daily Traffic Trend (30d)",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 1,
          "rawSql": "SELECT toStartOfInterval(hour, INTERVAL 1 DAY) AS t, sum(session_count) AS sessions, sum(total_bytes) / 1073741824 AS gb FROM ipdr.ipdr_hourly_traffic WHERE hour >= now() - INTERVAL 30 DAY GROUP BY t ORDER BY t",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "fillOpacity": 15
          }
        }
      },
      "description": "30-day trend of total sessions and bandwidth"
    },
    {
      "title": "Traffic Statistics",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 14
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "rawSql": "SELECT count() AS sessions FROM ipdr.ipdr_records WHERE $__timeFilter(timestamp)",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      },
      "description": "Total sessions in selected time range"
    },
    {
      "title": "Avg Bandwidth per Session",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 14
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "rawSql": "SELECT sum(bytes_total) / count() AS avg_bytes FROM ipdr.ipdr_records WHERE $__timeFilter(timestamp)",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        }
      },
      "description": "Average bytes per session in the selected time range"
    },
    {
      "title": "Peak Bandwidth (5 min)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 14
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "ClickHouse"
          },
          "format": 0,
          "rawSql": "SELECT max(total_bytes) AS peak FROM ipdr.ipdr_hourly_traffic WHERE hour >= now() - INTERVAL 5 MINUTE",
          "queryType": "sql"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1000000000
              },
              {
                "color": "red",
                "value": 10000000000
              }
            ]
          }
        }
      },
      "description": "Peak bandwidth in the last 5 minutes"
    }
  ],
  "time": {
    "from": "now-7d",
    "to": "now"
  }
}